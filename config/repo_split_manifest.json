    "shared-salesforce-core": {
      "purpose": "Small shared package or vendored module used by both repos for Salesforce auth, REST helpers, period primitives, and common constants.",
      "initial_contents": [
        "Salesforce CLI auth helper wrapping `sf org display --target-org apro@simcorp.com --json`",
        "Wave/REST request wrapper with retry and API version defaults",
        "Period utilities if both repos need calendar language",
        "Non-secret org constants only"
      ],
      "do_not_include": [
        ".env",
        "Salesforce access tokens",
        "generated output artifacts",
        "deck templates",
        "dashboard-specific metric contracts"
      ]
    },
    "legacy-parking-lot": {
      "purpose": "Tracked legacy or archived material that should not be copied into either clean repo during first cutover unless it is explicitly revived.",
      "include": {
        "root_files": [
          "run_workflow.sh"
        ],
        "directories": [
          "scripts/_archive/"
        ]
      }
    }
  },
  "split_rules": {
    "no_cross_imports_after_cutover": true,
    "monthly_decks_may_read_crm_exports_only_as_artifacts": true,
    "crm_analytics_must_not_import_monthly_deck_modules": true,
    "shared_code_must_be_secret_free": true,
    "generated_output_stays_out_of_both_git_histories_unless_explicitly_whitelisted": true
  },
  "first_cutover_gate": [
    "CRM repo: `make verify-static` passes without monthly deck files.",
    "Monthly decks repo: targeted monthly tests pass and `run_sales_director_monthly_master_builder.py --plan-only --json` resolves one director.",
    "No import from monthly deck modules remains in CRM Analytics dashboard builders.",
    "No import from CRM dashboard builders remains in monthly deck cadence scripts.",
    "GitHub Actions monthly schedule points only at the monthly-decks repo."
  ]
