        "high engagement prospects",
        "current systems identified",
        "need identified",
        "investment considerations identified"
      ]
    },
    {
      "stage": 2,
      "label": "Discovery",
      "primary_owner": ["Sales Manager"],
      "focus": [
        "active meetings",
        "decision process visible",
        "expected timeline",
        "PAIC complete",
        "decision makers identified",
        "scope and operating model identified",
        "price guidance provided"
      ]
    },
    {
      "stage": 3,
      "label": "Engagement",
      "primary_owner": ["Sales Manager"],
      "focus": [
        "buying process confirmed",
        "business case forming",
        "timeline confirmed",
        "budget / investment evident",
        "TAS assessment complete",
        "relationship map built",
        "shortlist trajectory"
      ]
