        "close plan emerging"
      ]
    },
    {
      "stage": 5,
      "label": "Preferred",
      "primary_owner": ["Sales Manager"],
      "focus": [
        "preferred vendor status",
        "close plan created",
        "legal and commercial workshops aligned"
      ]
    },
    {
      "stage": 6,
      "label": "Contracting",
      "primary_owner": ["Sales Manager", "Deal Desk"],
      "focus": [
        "redlines received",
        "final price agreed",
        "contract aligned",
        "implementation terms aligned"
      ]
