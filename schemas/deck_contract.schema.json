{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crm-analytics.simcorp.local/schemas/deck_contract.schema.json",
  "title": "monthly_platform.deck_contract.v2",
  "description": "Track E deck contract (v2). Retargeted from the 6-slide source-backed control deck to the director-facing Sales Director Monthly deck per Reading B (2026-04-26). Profiles register multiple deck shapes; director_monthly is active and primary, control_deck is declared but deferred. Cross-reference checks (workbook sheet/column existence, mart/column existence, schema_id registration, template digest) are enforced by scripts/monthly_platform/deck_contract.py on top of this structural schema.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "brand", "data_sources", "profiles"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "monthly_platform.deck_contract.v2"
    },
    "brand": { "$ref": "#/$defs/brand" },
    "director_profiles": { "$ref": "#/$defs/director_profiles_ref" },
    "data_sources": { "$ref": "#/$defs/data_sources" },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": { "$ref": "#/$defs/profile" }
      },
      "additionalProperties": false,
      "description": "Map of profile_id -> profile. At least one profile must have status: active."
    }
  },
  "$defs": {
    "brand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["template", "expected_template_sha256"],
      "properties": {
        "template": { "type": "string", "minLength": 1 },
        "expected_template_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "expected_template_size_bytes": { "type": "integer", "minimum": 1 },
        "expected_slide_master_count": { "type": "integer", "minimum": 1 },
        "required_layouts": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "theme": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fonts": {
              "type": "object",
              "additionalProperties": { "type": "string", "minLength": 1 }
            },
            "colors": {
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "pattern": "^#[0-9A-Fa-f]{6}$"
              }
            }
          }
        }
      }
    },
    "director_profiles_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "required_count", "required_fields"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "required_count": { "type": "integer", "minimum": 1 },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "description": "Pointer to the external director presets file (e.g. config/sales_director_md1_presets.json). Validator checks the file exists and contains the required count/fields."
    },
    "data_sources": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "director_workbook": { "$ref": "#/$defs/data_source_workbook" },
        "warehouse": { "$ref": "#/$defs/data_source_warehouse" }
      }
    },
    "data_source_workbook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "contract", "required_sheets"],
      "properties": {
        "type": { "const": "excel_workbook" },
        "contract": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "required_sheets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "data_source_warehouse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "required_marts"],
      "properties": {
        "type": { "const": "parquet_warehouse" },
        "description": { "type": "string" },
        "required_marts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "expected_slide_count"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["active", "deferred", "archived"]
        },
        "priority": {
          "type": "string",
          "enum": [
            "primary_release_artifact",
            "internal_control_artifact",
            "experimental"
          ]
        },
        "builder_lineage": { "type": "string" },
        "anchor_artifact": { "type": "string" },
        "anchor_workbook": { "type": "string" },
        "expected_slide_count": { "type": "integer", "minimum": 1 },
        "layout": { "type": "string" },
        "note": { "type": "string" },
        "run_metadata": { "$ref": "#/$defs/run_metadata" },
        "slides": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/slide" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "active" } } },
          "then": { "required": ["slides", "run_metadata"] }
        }
      ]
    },
    "run_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["presentation_month", "snapshot_date", "analysis_scope"],
      "properties": {
        "presentation_month": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        },
        "snapshot_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "prior_snapshot_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "analysis_scope": { "type": "string", "minLength": 1 }
      }
    },
    "slide": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slide_number",
        "title",
        "layout",
        "required_takeaway",
        "required_source_notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "slide_number": { "type": "integer", "minimum": 1 },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 48,
          "description": "Stable slide title. Currency, deal counts, warning glyphs, and dynamic numbers belong in generated_takeaway, not here."
        },
        "purpose": { "type": "string" },
        "layout": { "type": "string", "minLength": 1 },
        "static": {
          "type": "boolean",
          "description": "Set true for slides whose content does not vary per run (e.g. legal notice). Static slides are exempt from period/population/movement_window checks."
        },
        "required_takeaway": { "$ref": "#/$defs/takeaway_spec" },
        "required_source_notes": {
          "type": "array",
          "minItems": 0,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "required_links": {
          "type": "array",
          "items": { "$ref": "#/$defs/link_spec" }
        },
        "legacy_title_patterns": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 },
          "description": "Optional regex patterns the PPTX checker accepts as the produced slide title until the builder is updated to emit the stable title. Warning, not blocker."
        },
        "period": { "$ref": "#/$defs/period" },
        "population": { "$ref": "#/$defs/population" },
        "movement_window": { "$ref": "#/$defs/movement_window" },
        "definition": {
          "type": "string",
          "enum": [
            "opening_pipeline",
            "final_open_pipeline",
            "closed_outcome",
            "historical_trending_delta"
          ]
        },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/metric_binding" }
        },
        "tables": {
          "type": "array",
          "items": { "$ref": "#/$defs/table_binding" }
        }
      }
    },
    "takeaway_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": {
        "required": { "type": "boolean" },
        "max_chars": { "type": "integer", "minimum": 1, "maximum": 400 },
        "template": { "type": "string", "minLength": 1 },
        "required_metrics": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "required": { "const": true } } },
          "then": { "required": ["max_chars", "template", "required_metrics"] }
        }
      ]
    },
    "link_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "kind"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "label": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "salesforce_list_view",
            "salesforce_report",
            "sharepoint",
            "external_url"
          ]
        }
      }
    },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "start", "end"],
      "properties": {
        "role": {
          "type": "string",
          "enum": ["q1", "q2", "q3", "q4", "q2_q3", "fy26", "open"]
        },
        "start": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "end": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      }
    },
    "population": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "territory", "close_date_scope"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Land", "Renewal", "Land+Renewal", "Other"]
        },
        "territory": { "type": "string", "minLength": 1 },
        "close_date_scope": {
          "type": "string",
          "enum": [
            "current_close_date",
            "q1_original_close_date",
            "q1_historical_snapshot",
            "current_q1_close_date"
          ]
        }
      }
    },
    "movement_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 }
      }
    },
    "metric_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "aggregation"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "source": {
          "type": "string",
          "enum": ["director_workbook", "warehouse"]
        },
        "sheet": { "type": "string", "minLength": 1 },
        "mart": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "column": { "type": "string", "minLength": 1 },
        "aggregation": {
          "type": "string",
          "enum": [
            "scalar",
            "sum",
            "min",
            "max",
            "mean",
            "count",
            "distinct_count",
            "row_count"
          ]
        },
        "filters": {
          "type": "object",
          "description": "Free-form filter map; semantics resolved by the binding resolver."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "source": { "const": "director_workbook" } }
          },
          "then": { "required": ["sheet", "column"] }
        },
        {
          "if": { "properties": { "source": { "const": "warehouse" } } },
          "then": { "required": ["mart", "column"] }
        }
      ]
    },
    "table_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "columns"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "binding_type": {
          "type": "string",
          "enum": ["direct_workbook_table", "derived_table"],
          "description": "How the binding resolver should treat this table. direct_workbook_table = per-row slice of the source sheet (default for back-compat). derived_table = aggregate / pivoted / bridge view produced by a named transform."
        },
        "evidence_only": {
          "type": "boolean",
          "description": "Set true for supporting/drill-through tables that should not appear in the produced PPTX. PPTX checker excludes evidence_only tables from per-slide table-count expectations."
        },
        "display_grain": {
          "type": "string",
          "enum": [
            "opportunity",
            "owner",
            "stage",
            "forecast_category",
            "bucket",
            "snapshot",
            "approval_status"
          ]
        },
        "source_grain": {
          "type": "string",
          "enum": [
            "opportunity",
            "owner",
            "stage",
            "forecast_category",
            "bucket",
            "snapshot",
            "approval_status"
          ]
        },
        "transform_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Required when binding_type=derived_table. The binding resolver verifies the transform is registered in monthly_platform.deck_transforms."
        },
        "snapshot_roles": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "description": "Map from transform-input name to a snapshot_role declared in director_workbook_contract.yaml. Used by derived_table bindings."
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/derived_row" },
          "description": "Required when binding_type=derived_table. Declares the bucket/group rows the displayed table is supposed to contain."
        },
        "source": {
          "type": "string",
          "enum": ["director_workbook", "warehouse"]
        },
        "sheet": { "type": "string", "minLength": 1 },
        "mart": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "filters": {
          "type": "object",
          "description": "Free-form filter map; the binding resolver verifies referenced columns exist on the source."
        },
        "group_by": { "type": "string", "minLength": 1 },
        "max_rows": { "type": "integer", "minimum": 1, "maximum": 100 },
        "sort": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "order"],
            "properties": {
              "field": { "type": "string", "minLength": 1 },
              "order": { "type": "string", "enum": ["asc", "desc"] },
              "aggregation": {
                "type": "string",
                "enum": ["sum", "min", "max", "mean", "count", "row_count"]
              }
            }
          }
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/table_column" }
        },
        "legacy_header_sets": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "description": "Optional list of acceptable produced-PPTX header tuples. Each inner array is an ordered list of regex patterns matching the actual first-row headers. The PPTX checker accepts any match here as a WARNING (legacy_header_drift), not a blocker, mirroring legacy_title_patterns. Mismatches against BOTH the stable columns[].header AND every legacy_header_sets entry are blockers (table_header_mismatch)."
        },
        "header_pattern_sets": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "description": "Optional list of CANONICAL header tuples expressed as regex patterns. Use for tables whose headers are dynamic-by-design (e.g. snapshot dates). A match here returns pass_stable (not warning). Distinct from legacy_header_sets — the latter is transition-only, the former is the contract's accepted canonical shape."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "source": { "const": "director_workbook" } }
          },
          "then": { "required": ["sheet"] }
        },
        {
          "if": { "properties": { "source": { "const": "warehouse" } } },
          "then": { "required": ["mart"] }
        },
        {
          "if": {
            "properties": { "binding_type": { "const": "derived_table" } },
            "required": ["binding_type"]
          },
          "then": {
            "required": [
              "transform_id",
              "rows",
              "display_grain",
              "source_grain"
            ]
          }
        }
      ]
    },
    "derived_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "label": { "type": "string", "minLength": 1 },
        "origin": {
          "type": "string",
          "enum": [
            "opening_snapshot",
            "latest_snapshot",
            "closed_outcome",
            "net_inflow",
            "arr_delta_positive",
            "arr_delta_negative",
            "bridge_total",
            "static"
          ]
        }
      }
    },
    "table_column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "header"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "header": { "type": "string", "minLength": 1 },
        "source_column": { "type": "string", "minLength": 1 },
        "computed": {
          "type": "string",
          "enum": [
            "row_count",
            "days_to_close",
            "readiness_status",
            "bucket_label",
            "bucket_arr_impact"
          ]
        },
        "snapshot_role": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Reference to a semantic role declared in director_workbook_contract.yaml::snapshot_roles. Resolved to a physical column at runtime by the binding resolver using the role's column_pattern + selection (or runtime value)."
        },
        "joined_from": {
          "type": "string",
          "minLength": 1,
          "description": "Sheet name to enrich from (e.g. Activity Volume)."
        },
        "aggregation": {
          "type": "string",
          "enum": ["sum", "min", "max", "mean", "count", "row_count"]
        },
        "format": {
          "type": "string",
          "enum": ["eur_compact", "yyyy_mm_dd", "number_1dp", "percent", "raw"]
        },
        "max_chars": { "type": "integer", "minimum": 4, "maximum": 80 }
      },
      "anyOf": [
        { "required": ["source_column"] },
        { "required": ["computed"] },
        { "required": ["snapshot_role"] }
      ]
    }
  }
}
