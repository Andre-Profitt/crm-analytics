{
  "$schema": "https://specs.frictionlessdata.io/table-schema/",
  "name": "mart_director_source_health",
  "title": "Per-director source-health rollup (mart tier)",
  "description": "One row per distinct director value in the audit. Anchored to the 2026-04-26 v20d ETL spine checkpoint (10 director rows in v20c).",
  "fields": [
    {
      "name": "snapshot_date",
      "type": "string",
      "format": "default",
      "constraints": {
        "required": true,
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      }
    },
    {
      "name": "run_id",
      "type": "string",
      "constraints": { "required": true, "minLength": 1 }
    },
    {
      "name": "director",
      "type": "string",
      "description": "Director display name; empty string for global-scope sources (the marts builder substitutes \"\" when grouping)."
    },
    {
      "name": "source_count",
      "type": "integer",
      "constraints": { "required": true, "minimum": 0 }
    },
    {
      "name": "ok_source_count",
      "type": "integer",
      "constraints": { "required": true, "minimum": 0 }
    },
    {
      "name": "warning_source_count",
      "type": "integer",
      "constraints": { "required": true, "minimum": 0 }
    },
    {
      "name": "blocked_source_count",
      "type": "integer",
      "constraints": { "required": true, "minimum": 0 }
    },
    {
      "name": "total_row_count",
      "type": "integer",
      "constraints": { "required": true, "minimum": 0 }
    },
    {
      "name": "total_finding_count",
      "type": "integer",
      "constraints": { "required": true, "minimum": 0 }
    }
  ],
  "primaryKey": ["snapshot_date", "run_id", "director"]
}
